@page "/samples/distance-transform"
@using OpenCvSharp
@inject IJSRuntime jsRuntime
@implements IDisposable

<PageTitle>Distance Transform</PageTitle>

<h1>Distance Transform</h1>

<p>
    Paint a filled blob, then <code>Cv2.DistanceTransform</code> colors every pixel by how far it
    is from the nearest edge - a heatmap of "how thick is this part of the shape", not something a
    canvas blur can approximate.
</p>

<div style="display:flex; gap:1rem; align-items:flex-start; flex-wrap:wrap;">
    <div style="position:relative; width:256px; height:256px;"
         @onmousedown="OnMouseDown" @onmousemove="OnMouseMove" @onmouseup="OnMouseUp" @onmouseleave="OnMouseUp">
        <canvas @ref="drawCanvas" width="256" height="256" style="position:absolute; left:0; top:0; border:1px solid gray; cursor:crosshair;"></canvas>
    </div>
    <canvas @ref="distanceCanvas" width="256" height="256" style="border:1px solid gray;"></canvas>
</div>

<div>
    <button @onclick="ClearAsync">Clear</button>
    <button @onclick="AnalyzeDistanceAsync">Distance transform</button>
</div>
<p><em>@status</em></p>

@code {
    private const int CanvasSize = 256;

    private readonly Mat drawingMat = new(new Size(CanvasSize, CanvasSize), MatType.CV_8UC1, Scalar.Black);
    private ElementReference drawCanvas;
    private ElementReference distanceCanvas;
    private CanvasClient? drawCanvasClient;
    private CanvasClient? distanceCanvasClient;

    private bool isDrawing;
    private Point lastPoint;
    private string status = "Paint a filled blob, then run the distance transform.";

    public void Dispose() => drawingMat.Dispose();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (!firstRender)
            return;

        drawCanvasClient ??= new CanvasClient(jsRuntime, drawCanvas);
        distanceCanvasClient ??= new CanvasClient(jsRuntime, distanceCanvas);
        await drawCanvasClient.DrawMatAsync(drawingMat);
        await ClearCanvasAsync(distanceCanvasClient);
    }

    private async Task OnMouseDown(MouseEventArgs e)
    {
        isDrawing = true;
        lastPoint = new Point((int)e.OffsetX, (int)e.OffsetY);

        // A plain click with no drag wouldn't otherwise leave any mark, since only OnMouseMove
        // draws - paint a dot immediately so a single click is visibly a brush stroke too.
        Cv2.Circle(drawingMat, lastPoint, 9, Scalar.White, thickness: -1);
        await drawCanvasClient!.DrawMatAsync(drawingMat);
    }

    private async Task OnMouseMove(MouseEventArgs e)
    {
        if (!isDrawing)
            return;

        var point = new Point((int)e.OffsetX, (int)e.OffsetY);
        Cv2.Line(drawingMat, lastPoint, point, Scalar.White, thickness: 18);
        lastPoint = point;
        await drawCanvasClient!.DrawMatAsync(drawingMat);
    }

    private void OnMouseUp(MouseEventArgs e) => isDrawing = false;

    private async Task ClearAsync()
    {
        drawingMat.SetTo(Scalar.Black);
        status = "Paint a filled blob, then run the distance transform.";
        await drawCanvasClient!.DrawMatAsync(drawingMat);
        await ClearCanvasAsync(distanceCanvasClient!);
    }

    private static async Task ClearCanvasAsync(CanvasClient client)
    {
        using var blank = new Mat(new Size(CanvasSize, CanvasSize), MatType.CV_8UC3, Scalar.All(20));
        await client.DrawMatAsync(blank);
    }

    private async Task AnalyzeDistanceAsync()
    {
        using var dist = new Mat();
        Cv2.DistanceTransform(drawingMat, dist, DistanceTypes.L2, DistanceTransformMasks.Mask5);

        using var normalized = new Mat();
        Cv2.Normalize(dist, normalized, 0, 255, NormTypes.MinMax);
        using var byteMat = new Mat();
        normalized.ConvertTo(byteMat, MatType.CV_8UC1);

        using var colored = new Mat();
        Cv2.ApplyColorMap(byteMat, colored, ColormapTypes.Hot);

        await distanceCanvasClient!.DrawMatAsync(colored);
        status = "Brighter pixels are further from the shape's edge.";
    }
}
