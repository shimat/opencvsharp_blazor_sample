@page "/"
@using BlazorApp.Shared

<PageTitle>OpenCvSharp Blazor Sample</PageTitle>

<h1>OpenCvSharp + Blazor WebAssembly</h1>

<p>
    Code samples showing <a href="https://github.com/shimat/opencvsharp" target="_blank">OpenCvSharp</a>
    running entirely in the browser via Blazor WebAssembly - no server-side processing involved.
</p>

<p><a href="build-info">Build Info</a> - the OpenCV build compiled into this app's WebAssembly binary.</p>

@foreach (var group in SampleCatalog.ByCategory)
{
    <h2 class="sample-category-title">@group.Key</h2>
    <div class="sample-grid">
        @foreach (var sample in group)
        {
            <a class="sample-card" href="@sample.Route">
                <span class="sample-card-icon icon-@sample.Icon" aria-hidden="true"></span>
                <div class="sample-card-body">
                    <h3>@sample.Title</h3>
                    <p>@sample.Description</p>
                    <div class="sample-card-tags">
                        @foreach (var tag in sample.Tags)
                        {
                            <span class="sample-tag">@tag</span>
                        }
                    </div>
                </div>
            </a>
        }
    </div>
}
