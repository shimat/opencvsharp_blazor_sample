@page "/samples/dnn-detection"
@using OpenCvSharp
@inject IJSRuntime jsRuntime
@inject HttpClient httpClient
@implements IAsyncDisposable

<PageTitle>DNN Face Detection (YuNet)</PageTitle>

<h1>DNN Face Detection (YuNet)</h1>

<p>
    Runs <code>Cv2.FaceDetectorYN</code> - a small ONNX neural network, not a Haar cascade -
    against a live webcam feed entirely in the browser, drawing both the face box and its five
    landmark points (eyes, nose tip, mouth corners).
</p>

<video @ref="videoElement" autoplay muted playsinline style="display:none"></video>
<canvas @ref="captureCanvas" style="display:none"></canvas>
<canvas @ref="resultCanvas" width="480" height="360" style="border:1px solid gray;"></canvas>

<div>
    <button @onclick="StartAsync" disabled="@running">Start</button>
    <button @onclick="StopAsync" disabled="@(!running)">Stop</button>
</div>
<p>@statusMessage</p>

@code {
    private const int FrameWidth = 480;
    private const int FrameHeight = 360;

    // FaceDetectorYN.Create bakes the input size into the model, and this build has no
    // SetInputSize binding to change it afterward - so every captured frame must be exactly
    // this size, which webcam.js's captureFrame already guarantees by drawing straight at
    // (FrameWidth, FrameHeight) instead of the camera's native resolution.
    private static readonly Size DetectorInputSize = new(FrameWidth, FrameHeight);

    private ElementReference videoElement;
    private ElementReference captureCanvas;
    private ElementReference resultCanvas;
    private WebcamClient? webcamClient;
    private CanvasClient? resultCanvasClient;
    private FaceDetectorYN? detector;
    private CancellationTokenSource? cts;
    private Task? loopTask;
    private bool running;
    private string statusMessage = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (!firstRender)
            return;

        webcamClient ??= new WebcamClient(jsRuntime, videoElement, captureCanvas);
        resultCanvasClient ??= new CanvasClient(jsRuntime, resultCanvas);
    }

    private async Task EnsureDetectorLoadedAsync()
    {
        if (detector is not null)
            return;

        var modelBytes = await httpClient.GetByteArrayAsync("models/face_detection_yunet_2023mar.onnx");
        const string modelPath = "face_detection_yunet_2023mar.onnx";
        await File.WriteAllBytesAsync(modelPath, modelBytes);
        detector = FaceDetectorYN.Create(modelPath, "", DetectorInputSize);
    }

    private async Task StartAsync()
    {
        if (running || webcamClient is null)
            return;

        running = true;
        statusMessage = "Requesting camera access...";
        try
        {
            await EnsureDetectorLoadedAsync();
            await webcamClient.StartAsync();
        }
        catch (Exception ex)
        {
            statusMessage = $"Couldn't start the camera: {ex.Message}";
            running = false;
            return;
        }

        statusMessage = "";
        cts = new CancellationTokenSource();
        loopTask = RunLoopAsync(cts.Token);
    }

    private async Task StopAsync()
    {
        if (!running)
            return;

        running = false;
        cts?.Cancel();

        if (webcamClient is not null)
            await webcamClient.StopAsync();
    }

    private async Task RunLoopAsync(CancellationToken token)
    {
        while (!token.IsCancellationRequested)
        {
            try
            {
                await CaptureAndDetectOnceAsync();
            }
            catch
            {
                // Ignore a transient capture/detection failure and keep the loop alive.
            }

            try
            {
                await Task.Delay(30, token);
            }
            catch (TaskCanceledException)
            {
                break;
            }
        }
    }

    private async Task CaptureAndDetectOnceAsync()
    {
        if (webcamClient is null || resultCanvasClient is null || detector is null)
            return;

        var frameBytes = await webcamClient.CaptureFrameAsync(FrameWidth, FrameHeight);
        if (frameBytes.Length == 0)
            return;

        using var colorMat = Mat.FromImageData(frameBytes);

        using var faces = new Mat();
        detector.Detect(colorMat, faces);

        // Each row is [x, y, w, h, then 5 (x, y) landmark pairs, then a confidence score] - see
        // https://github.com/opencv/opencv_zoo/tree/main/models/face_detection_yunet. Bail out if
        // this build's dnn engine ever returns a different column count instead of trusting it -
        // reading past the Mat's actual columns is a native out-of-bounds access, not a
        // catchable .NET exception, on this wasm build.
        const int expectedCols = 15;
        if (faces.Cols != 0 && faces.Cols != expectedCols)
            return;

        var imageBounds = new Rect(0, 0, colorMat.Width, colorMat.Height);
        for (var i = 0; i < faces.Rows; i++)
        {
            var x = faces.At<float>(i, 0);
            var y = faces.At<float>(i, 1);
            var w = faces.At<float>(i, 2);
            var h = faces.At<float>(i, 3);
            if (!IsFinite(x) || !IsFinite(y) || !IsFinite(w) || !IsFinite(h))
                continue;

            var rect = new Rect((int)x, (int)y, (int)w, (int)h).Intersect(imageBounds);
            if (rect.Width <= 0 || rect.Height <= 0)
                continue;

            Cv2.Rectangle(colorMat, rect, Scalar.LimeGreen, thickness: 2);

            for (var landmark = 0; landmark < 5; landmark++)
            {
                var lx = faces.At<float>(i, 4 + landmark * 2);
                var ly = faces.At<float>(i, 4 + landmark * 2 + 1);
                if (!IsFinite(lx) || !IsFinite(ly))
                    continue;

                var point = new Point((int)lx, (int)ly);
                if (point.X < 0 || point.Y < 0 || point.X >= colorMat.Width || point.Y >= colorMat.Height)
                    continue;

                Cv2.Circle(colorMat, point, radius: 2, Scalar.Yellow, thickness: -1);
            }
        }

        await resultCanvasClient.DrawMatAsync(colorMat);
    }

    private static bool IsFinite(float value) => !float.IsNaN(value) && !float.IsInfinity(value);

    public async ValueTask DisposeAsync()
    {
        cts?.Cancel();
        if (running && webcamClient is not null)
        {
            await webcamClient.StopAsync();
            running = false;
        }
        if (loopTask is not null)
            await loopTask;
        detector?.Dispose();
        cts?.Dispose();
    }
}
