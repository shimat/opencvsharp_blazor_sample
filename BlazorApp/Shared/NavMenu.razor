<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">BlazorApp</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon icon-home" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="build-info">
                <span class="nav-icon icon-info" aria-hidden="true"></span> Build Info
            </NavLink>
        </div>

        @foreach (var group in SampleCatalog.ByCategory)
        {
            var category = group.Key;
            <button type="button" class="nav-category-header" @onclick="() => ToggleCategory(category)" @onclick:stopPropagation="true">
                <span class="nav-category-chevron @(IsExpanded(category) ? "expanded" : "")" aria-hidden="true"></span>
                @category
            </button>
            <div class="nav-category-body @(IsExpanded(category) ? "expanded" : "")">
                @foreach (var sample in group)
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="@sample.Route">
                            <span class="nav-icon icon-@sample.Icon" aria-hidden="true"></span> @sample.Title
                        </NavLink>
                    </div>
                }
            </div>
        }
    </nav>
</div>

@implements IDisposable
@code {
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;

    private bool collapseNavMenu = true;
    private readonly HashSet<string> expandedCategories = new();

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        expandedCategories.Add(GetCurrentCategory() ?? SampleCatalog.Samples[0].Category);
    }

    // Keeps the current page's category expanded after client-side navigation - OnInitialized only
    // runs once for this component's lifetime, so without this a category other than the one
    // active on first load never auto-expands.
    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var category = GetCurrentCategory();
        if (category is not null && expandedCategories.Add(category))
            InvokeAsync(StateHasChanged);
    }

    private string? GetCurrentCategory()
    {
        var currentRoute = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).TrimEnd('/');
        return SampleCatalog.Samples.FirstOrDefault(s => s.Route == currentRoute)?.Category;
    }

    public void Dispose() => NavigationManager.LocationChanged -= OnLocationChanged;

    private bool IsExpanded(string category) => expandedCategories.Contains(category);

    private void ToggleCategory(string category)
    {
        if (!expandedCategories.Add(category))
        {
            expandedCategories.Remove(category);
        }
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
